# Copy to .env and fill in. Do NOT commit .env to git.
# Used by Supabase CLI (e.g. config.toml env() references) and local app.

# Supabase (from Dashboard → Project Settings → API)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=

# Optional: for local Supabase Studio AI
# OPENAI_API_KEY=

# Optional: OAuth / SMTP (if enabling in config.toml)
# GITHUB_CLIENT_ID=
# GITHUB_SECRET=
# SENDGRID_API_KEY=
